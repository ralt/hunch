# hunch environment. Copy to .env.local and fill in secrets (never commit secrets).
APP_ENV=dev
APP_SECRET=change_me_in_env_local

# Claude: each user sets their OWN Anthropic API key in the app (Settings page),
# stored encrypted at rest — there is no global key.

# PostgreSQL: settings (users, mailboxes) + AI conversations. Emails live on the
# filesystem (var/maildir), not here.
DATABASE_URL=postgresql://app:app@127.0.0.1:5432/app?serverVersion=16&charset=utf8

# Meilisearch (derived search index; managed locally by `hunch:meili` or docker).
MEILI_URL=http://127.0.0.1:7700
MEILI_INDEX=hunch
# MEILISEARCH_API_KEY=

# On-device embedding model (runs inside Meilisearch's HuggingFace embedder).
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Background jobs (mailbox sync) — Doctrine/Postgres-backed queue, no extra infra.
MESSENGER_TRANSPORT_DSN=doctrine://default

# SSRF hardening. Link-local (cloud metadata) is always blocked. Set to 1 on
# multi-tenant/hosted deployments to also block private/loopback hosts for the
# user-supplied Ollama URL and IMAP host (self-hosted localhost setups keep 0).
HUNCH_STRICT_SSRF=0

# IMAP accounts are configured per-user in the app (the /mailboxes page),
# stored in Postgres with the password encrypted at rest — not via env.
