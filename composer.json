{
    "name": "ralt/hunch",
    "description": "Local, AI-assisted semantic email search — a Symfony AI showcase",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "symfony/framework-bundle": "^7.2",
        "symfony/runtime": "^7.2",
        "symfony/console": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/yaml": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "twig/twig": "^3.0",
        "symfony/http-client": "^7.2",
        "symfony/process": "^7.2",
        "symfony/finder": "^7.2",
        "nyholm/psr7": "^1.8",
        "php-http/discovery": "^1.19",

        "symfony/ai-bundle": "*",
        "symfony/ai-agent": "*",
        "symfony/ai-anthropic-platform": "*",

        "meilisearch/meilisearch-php": "^1.10",
        "webklex/php-imap": "^6.0",

        "symfony/security-bundle": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/doctrine-messenger": "^7.2",
        "symfony/mercure-bundle": "^0.4",
        "doctrine/orm": "^3.3",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^2.13"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
