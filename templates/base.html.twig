<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <title>{% block title %}Hunch — semantic email search{% endblock %}</title>
    <style>
        :root { --bg:#f4f1ea; --fg:#2b2b2b; --muted:#8a8275; --accent:#b5552d; --card:#fff; --line:#ece6d8; }
        * { box-sizing: border-box; }
        body { margin:0; font:16px/1.5 -apple-system,Segoe UI,Roboto,sans-serif; background:var(--bg); color:var(--fg); }
        a { color: var(--accent); }
        nav { display:flex; gap:1rem; align-items:center; padding:.8rem 1rem; border-bottom:1px solid var(--line); background:var(--card); }
        nav .brand { font-weight:700; letter-spacing:-.02em; }
        nav .spacer { flex:1; }
        nav .who { color:var(--muted); font-size:.85rem; }
        .wrap { max-width: 820px; margin: 0 auto; padding: 1.5rem 1rem 4rem; }
        h1 { font-weight:700; letter-spacing:-.02em; }
        h1 .dim, .dim { color: var(--muted); font-weight:400; }
        form.search { display:flex; gap:.5rem; margin:1.25rem 0; }
        input[type=text], input[type=email], input[type=password], input[type=number], select {
            padding:.6rem .8rem; border:1px solid #ddd6c9; border-radius:10px; font-size:1rem; background:var(--card); width:100%; }
        form.search input { flex:1; }
        button { padding:.6rem 1.1rem; border:0; border-radius:10px; background:var(--accent); color:#fff; font-weight:600; cursor:pointer; }
        button.ghost { background:transparent; color:var(--muted); border:1px solid var(--line); }
        .bubble { padding:.7rem .95rem; border-radius:12px; margin:.5rem 0; max-width:85%; white-space:pre-wrap; }
        .user { background:#e9e3d6; margin-left:auto; }
        .assistant { background:var(--card); border:1px solid var(--line); }
        .card { background:var(--card); border:1px solid var(--line); border-radius:12px; padding:1rem; margin:.75rem 0; }
        .card h3 { margin:0 0 .25rem; font-size:1.05rem; }
        .meta { color:var(--muted); font-size:.85rem; }
        .reason { color:var(--accent); margin-top:.4rem; font-size:.92rem; }
        .flash { padding:.6rem .9rem; border-radius:10px; margin:.4rem 0; }
        .flash.error { background:#f7e0d8; color:#7a2e12; }
        .flash.success { background:#e3efe0; color:#2c5a2c; }
        .row { display:grid; grid-template-columns:1fr 1fr; gap:.6rem; }
        label { font-size:.85rem; color:var(--muted); display:block; margin:.4rem 0 .15rem; }
        .panel { max-width:420px; margin:3rem auto; }
        .recent a { display:block; padding:.3rem 0; }
    </style>
</head>
<body>
    <nav>
        <span class="brand">Hunch</span>
        {% if app.user %}
            <a href="{{ path('home') }}">Search</a>
            <a href="{{ path('mailboxes') }}">Mailboxes</a>
            <a href="{{ path('settings') }}">Settings</a>
            {% if is_granted('ROLE_ADMIN') %}<a href="{{ path('admin_users') }}">Admin</a>{% endif %}
            <span class="spacer"></span>
            <span class="who">{{ app.user.userIdentifier }}</span>
            <a href="{{ path('logout') }}">Log out</a>
        {% else %}
            <span class="spacer"></span>
            <a href="{{ path('login') }}">Log in</a>
        {% endif %}
    </nav>
    <div class="wrap">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash {{ type }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </div>
</body>
</html>
