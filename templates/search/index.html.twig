{% extends 'base.html.twig' %}

{# The search UI is a horizontal, scrollable pane manager (niri-style). #}
{% block bodyclass %}{{ app.user.mailboxes is not empty ? 'wm' : '' }}{% endblock %}

{% block body %}
    {% if app.user.mailboxes is empty %}
        <h1>Hunch <span class="dim">— find an email by describing it, not by keywords</span></h1>
        <div class="card">
            <h3>No mailboxes yet</h3>
            <p class="dim">There's nothing to search until you connect an email account.</p>
            <p><a href="{{ path('mailboxes') }}">Add a mailbox →</a></p>
        </div>
    {% else %}
        <div id="wm"
             data-mercure-url="{{ mercurePublicUrl }}"
             data-topic="{{ topic }}"
             data-conversation-id="{{ conversation ? conversation.id : '' }}"
             data-post-url="{{ path('search') }}"
             data-email-url="{{ path('email_view', {id: '0000000000000000000000000000000000000000'}) }}"
             data-candidates="{{ candidates|json_encode|e('html_attr') }}"
             data-presented="{{ presentedResults|json_encode|e('html_attr') }}">
            <div id="strip">

                <section class="win" id="win-conversation">
                    <header class="win-head">Conversation</header>
                    <div class="win-body" id="messages">
                        {% for m in (conversation ? conversation.messages : []) %}
                            <div class="bubble {{ m.role.value }}">{{ m.content }}</div>
                        {% endfor %}
                        {% if not conversation %}
                            <div class="intro dim">Describe the email you're after — a topic, a sender, roughly when. The agent searches, ranks matches on the right, and you open the one you meant.</div>
                            {% if recent %}
                                <div class="recent-head dim">Recent searches</div>
                                <div class="recent">
                                    {% for c in recent %}<a href="{{ path('home', {conversation: c.id}) }}">{{ c.title|default('(untitled)') }}</a>{% endfor %}
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                    <div class="win-foot">
                        <div id="status" class="dim" style="display:none"></div>
                        <form id="chat-form" class="search" autocomplete="off">
                            <input id="chat-input" type="text" name="message" autofocus
                                   placeholder="{{ conversation ? 'reply…' : 'e.g. that document the bank sent me about my mortgage' }}">
                            <button type="submit">Send</button>
                        </form>
                        {% if conversation %}<a class="dim newsearch" href="{{ path('home') }}">↺ start a new search</a>{% endif %}
                    </div>
                </section>

                <section class="win" id="win-results" hidden>
                    <header class="win-head">Results <span id="results-count" class="dim"></span></header>
                    <div class="win-body" id="results-list"></div>
                </section>

                <section class="win" id="win-email" hidden>
                    <header class="win-head"><span id="email-title">Email</span></header>
                    <div class="win-body" id="email-content"></div>
                </section>

            </div>
        </div>
    {% endif %}

    <style>
        /* Page shell: nav on top, the pane manager fills the rest. */
        body.wm { height:100vh; overflow:hidden; display:grid; grid-template-rows:auto 1fr; }
        body.wm .wrap { min-height:0; max-width:none; margin:0; padding:0; display:grid; }
        #wm { position:relative; overflow:hidden; }

        /* The strip is a row of fixed-width windows; JS pans it via translateX
           so the focused window sits centered in the viewport. */
        #strip { position:absolute; inset:0; display:flex; gap:20px; padding:18px;
                 align-items:stretch; transform:translateX(0);
                 transition:transform .38s cubic-bezier(.4,0,.2,1); will-change:transform; }

        .win { flex:0 0 min(680px, 88vw); display:grid; grid-template-rows:auto 1fr;
               background:var(--card); border:1px solid var(--line); border-radius:16px;
               overflow:hidden; box-shadow:0 8px 30px var(--glow); transition:border-color .2s, box-shadow .2s; }
        #win-conversation { grid-template-rows:auto 1fr auto; }
        .win.focused { border-color:var(--accent); box-shadow:0 10px 36px var(--glow); }
        .win-head { padding:.75rem 1.05rem; border-bottom:1px solid var(--line);
                    font-weight:600; font-size:.95rem; display:flex; gap:.5rem; align-items:baseline;
                    overflow:hidden; white-space:nowrap; text-overflow:ellipsis; }
        .win-body { min-height:0; overflow-y:auto; padding:1rem 1.05rem; }
        .win-foot { border-top:1px solid var(--line); padding:.6rem 1.05rem .8rem; }
        .win-foot form.search { margin:0; }
        .newsearch { display:inline-block; margin-top:.5rem; font-size:.85rem; }
        .intro { margin:.3rem 0 1.2rem; line-height:1.55; }
        .recent-head { font-size:.8rem; text-transform:uppercase; letter-spacing:.04em; margin-bottom:.2rem; }

        /* Result rows — live-ranked by match score. */
        .result-row { border:1px solid var(--line); border-radius:11px; padding:.7rem .8rem;
                       margin-bottom:.6rem; cursor:pointer; transition:border-color .15s, transform .15s; }
        .result-row:hover { border-color:var(--accent); transform:translateY(-1px); }
        .result-row.active { border-color:var(--accent); background:var(--glow); }
        .rr-top { display:flex; gap:.6rem; align-items:baseline; }
        .rr-subject { font-weight:600; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
        .rr-subject .pick { color:var(--accent); }
        .rr-score { color:var(--muted); font-size:.78rem; font-variant-numeric:tabular-nums; flex:0 0 auto; }
        .rr-meta { color:var(--muted); font-size:.82rem; margin:.15rem 0; }
        .rr-snippet { font-size:.85rem; color:var(--fg); opacity:.8; overflow:hidden;
                      display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; }
        .rr-bar { height:3px; border-radius:3px; background:var(--line); margin-top:.5rem; overflow:hidden; }
        .rr-bar i { display:block; height:100%; background:var(--accent); }
        .results-empty { color:var(--muted); font-size:.9rem; }

        /* Messages */
        #messages .intro:only-child { }
        .bubble { padding:.7rem .95rem; border-radius:12px; margin:.5rem 0; max-width:92%; white-space:pre-wrap; }
        .email-doc h2 { font-size:1.15rem; margin:0 0 .3rem; }
        .email-body { white-space:pre-wrap; word-wrap:break-word; font:14px/1.55 -apple-system,Segoe UI,Roboto,sans-serif;
                      margin-top:.8rem; }
        a.email-ref { color:var(--accent); font-weight:600; text-decoration:underline; text-underline-offset:2px; cursor:pointer; }
    </style>

    {% if app.user.mailboxes is not empty %}
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify/dist/purify.min.js"></script>
    <script>
    (function () {
        const wm = document.getElementById('wm');
        const strip = document.getElementById('strip');
        const messages = document.getElementById('messages');
        const form = document.getElementById('chat-form');
        const input = document.getElementById('chat-input');
        const statusEl = document.getElementById('status');
        const winConversation = document.getElementById('win-conversation');
        const winResults = document.getElementById('win-results');
        const winEmail = document.getElementById('win-email');
        const resultsList = document.getElementById('results-list');
        const resultsCount = document.getElementById('results-count');
        const emailTitle = document.getElementById('email-title');
        const emailContent = document.getElementById('email-content');

        const mercureUrl = wm.dataset.mercureUrl;
        const postUrl = wm.dataset.postUrl;
        const emailTmpl = wm.dataset.emailUrl;
        const placeholderId = '0000000000000000000000000000000000000000';
        let conversationId = wm.dataset.conversationId || null;
        let topic = wm.dataset.topic || null;
        let es = null;
        let focusedEl = winConversation;
        let activeEmailId = null;
        const pickedIds = new Set();
        const candidateIndex = {}; // number => {id, subject}, for "#12" links

        const md = (t) => (window.marked && window.DOMPurify)
            ? DOMPurify.sanitize(marked.parse(t || '')) : (t || '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c]));

        // --- Pane manager: center the focused window in the viewport ---------
        function focusWindow(el) {
            if (!el || el.hidden) return;
            focusedEl = el;
            document.querySelectorAll('.win').forEach(w => w.classList.toggle('focused', w === el));
            const tx = wm.clientWidth / 2 - (el.offsetLeft + el.offsetWidth / 2);
            strip.style.transform = 'translateX(' + tx + 'px)';
        }
        // Re-center on resize (widths/offsets change).
        let rz; window.addEventListener('resize', () => { clearTimeout(rz); rz = setTimeout(() => focusWindow(focusedEl), 120); });

        // Click a window to bring it to center; click a result to open its email.
        strip.addEventListener('click', (e) => {
            const row = e.target.closest('.result-row');
            if (row) { openEmail(row.dataset.id); return; }
            const ref = e.target.closest('a.email-ref');
            if (ref) { e.preventDefault(); openEmail(ref.dataset.id); return; }
            const win = e.target.closest('.win');
            if (win && win !== focusedEl) focusWindow(win);
        });

        // --- Assistant messages ---------------------------------------------
        function linkifyRefs(el) {
            const nodes = [];
            const w = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
            while (w.nextNode()) nodes.push(w.currentNode);
            nodes.forEach(node => {
                if (!/#\d+/.test(node.nodeValue)) return;
                const parts = node.nodeValue.split(/(#\d+)/);
                const frag = document.createDocumentFragment();
                let changed = false;
                parts.forEach(p => {
                    const m = /^#(\d+)$/.exec(p);
                    const info = m && candidateIndex[m[1]];
                    if (info) {
                        const a = document.createElement('a');
                        a.className = 'email-ref'; a.textContent = p;
                        a.href = '#'; a.dataset.id = info.id;
                        if (info.subject) a.title = 'Opens: ' + info.subject;
                        frag.appendChild(a); changed = true;
                    } else { frag.appendChild(document.createTextNode(p)); }
                });
                if (changed) node.parentNode.replaceChild(frag, node);
            });
        }

        function addBubble(role, text, asMarkdown) {
            const d = document.createElement('div');
            d.className = 'bubble ' + role;
            if (asMarkdown) { d.innerHTML = md(text); linkifyRefs(d); } else d.textContent = text;
            messages.appendChild(d); scrollMessages(); return d;
        }
        function scrollMessages() { requestAnimationFrame(() => { messages.scrollTop = messages.scrollHeight; }); }

        // --- Results pane (live-ranked) -------------------------------------
        function indexCandidates(list) {
            (list || []).forEach(c => { if (c.id) candidateIndex[c.n] = { id: c.id, subject: c.subject || '' }; });
        }
        let lastList = []; // remembered so a "picked" event can re-render in place
        function renderCandidates(list) {
            if (Array.isArray(list)) lastList = list;
            list = lastList;
            indexCandidates(list);
            if (list.length && winResults.hidden) winResults.hidden = false;
            resultsCount.textContent = list.length ? '· ' + list.length : '';
            if (!list.length) { resultsList.innerHTML = '<div class="results-empty">No matches yet…</div>'; return; }
            resultsList.innerHTML = '';
            list.forEach(c => {
                const pct = Math.round((c.score || 0) * 100);
                const row = document.createElement('div');
                row.className = 'result-row' + (c.id === activeEmailId ? ' active' : '');
                row.dataset.id = c.id;
                const pick = pickedIds.has(c.id) ? '<span class="pick" title="Claude picked this">★ </span>' : '';
                row.innerHTML =
                    '<div class="rr-top"><span class="rr-subject">' + pick + esc(c.subject || '(no subject)') + '</span>'
                    + '<span class="rr-score">' + pct + '%</span></div>'
                    + '<div class="rr-meta">' + esc((c.from || '') + (c.date ? ' · ' + c.date : '')) + '</div>'
                    + (c.snippet ? '<div class="rr-snippet">' + esc(c.snippet) + '</div>' : '')
                    + '<div class="rr-bar"><i style="width:' + pct + '%"></i></div>';
                resultsList.appendChild(row);
            });
        }
        function esc(s) { return (s || '').replace(/[<>&]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;'}[c])); }
        function markPicked(results) {
            (results || []).forEach(r => { if (r.id) pickedIds.add(r.id); });
        }

        // --- Email pane (single, reused) ------------------------------------
        async function openEmail(id) {
            if (!id) return;
            activeEmailId = id;
            document.querySelectorAll('.result-row').forEach(r => r.classList.toggle('active', r.dataset.id === id));
            winEmail.hidden = false;
            emailTitle.textContent = 'Email';
            emailContent.innerHTML = '<p class="dim">Loading…</p>';
            focusWindow(winEmail);
            try {
                const res = await fetch(emailTmpl.replace(placeholderId, id));
                if (!res.ok) { emailContent.innerHTML = '<p class="dim">Could not load this email.</p>'; return; }
                const d = await res.json();
                emailTitle.textContent = d.subject || '(no subject)';
                const doc = document.createElement('div'); doc.className = 'email-doc';
                const h2 = document.createElement('h2'); h2.textContent = d.subject || '(no subject)';
                const meta = document.createElement('div'); meta.className = 'meta';
                meta.textContent = (d.from || '') + (d.date ? ' · ' + d.date.substring(0, 10) : '');
                const body = document.createElement('div'); body.className = 'email-body'; body.textContent = d.body || '(no text body)';
                doc.append(h2, meta, body);
                emailContent.innerHTML = ''; emailContent.appendChild(doc);
            } catch (_) { emailContent.innerHTML = '<p class="dim">Could not load this email.</p>'; }
        }

        // --- Mercure stream --------------------------------------------------
        function openMercure(t) {
            if (!t || !mercureUrl || es) return;
            // mercureUrl may be relative (same-origin route on Upsun) or absolute
            // (local hub); resolving against the origin handles both.
            const u = new URL(mercureUrl, window.location.origin);
            u.searchParams.append('topic', t);
            es = new EventSource(u.toString());
            es.onmessage = (e) => { try { handle(JSON.parse(e.data)); } catch (_) {} };
        }
        function handle(p) {
            if (p.type === 'status') { statusEl.textContent = p.text; statusEl.style.display = 'block'; }
            else if (p.type === 'candidates') { renderCandidates(p.candidates); }
            else if (p.type === 'assistant') { statusEl.style.display = 'none'; renderCandidates(p.candidates); addBubble('assistant', p.text, true); }
            else if (p.type === 'results') { markPicked(p.results); renderCandidates(); }
            else if (p.type === 'done') { statusEl.style.display = 'none'; input.disabled = false; input.focus(); }
        }

        // --- Compose ---------------------------------------------------------
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = input.value.trim(); if (!text) return;
            focusWindow(winConversation);
            addBubble('user', text, false);
            input.value = ''; input.disabled = true;
            statusEl.textContent = 'Sending…'; statusEl.style.display = 'block';
            try {
                const res = await fetch(postUrl, {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message: text, conversation: conversationId }),
                });
                const d = await res.json();
                if (!res.ok) {
                    statusEl.style.display = 'none'; input.disabled = false;
                    addBubble('assistant', d.error || 'Something went wrong.', false);
                    if (d.redirect) setTimeout(() => { window.location = d.redirect; }, 1200);
                    return;
                }
                conversationId = d.conversationId;
                if (!topic) { topic = d.topic; openMercure(topic); }
            } catch (_) {
                statusEl.style.display = 'none'; input.disabled = false;
                addBubble('assistant', 'Network error — please retry.', false);
            }
        });

        // --- Boot ------------------------------------------------------------
        try { markPicked(JSON.parse(wm.dataset.presented || '[]')); } catch (_) {}
        try {
            const seed = JSON.parse(wm.dataset.candidates || '[]');
            if (Array.isArray(seed) && seed.length) renderCandidates(seed);
        } catch (_) {}
        messages.querySelectorAll('.bubble.assistant').forEach(b => { b.innerHTML = md(b.textContent); linkifyRefs(b); });
        scrollMessages();
        // Start centered on the conversation; results (if any) peek in from the right.
        requestAnimationFrame(() => focusWindow(winConversation));
        if (topic) openMercure(topic);
    })();
    </script>
    {% endif %}
{% endblock %}
